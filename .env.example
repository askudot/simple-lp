# ============================================
# SIMPLE LP — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT share your .env file!

# ── Wallet ─────────────────────────────────
# Your Solana wallet private key (base58 encoded)
# Generate new: npm run wallet:generate
# Or import existing: npm run wallet:import <your_secret_key>
WALLET_PRIVATE_KEY=

# ── RPC ────────────────────────────────────
# Solana RPC URL (get free key from Helius, QuickNode, or others)
# Get free Helius key: https://helius.xyz
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE

# ── Mode ───────────────────────────────────
# Set to "true" for testing (no real transactions)
DRY_RUN=false
