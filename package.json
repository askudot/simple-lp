{
  "name": "simple-lp",
  "version": "1.0.0",
  "type": "module",
  "description": "Simple Meteora DLMM pool screening & deploy",
  "scripts": {
    "start": "node --experimental-specifier-resolution=node index.js",
    "screen": "node --experimental-specifier-resolution=node index.js --screen",
    "positions": "node --experimental-specifier-resolution=node index.js --positions",
    "close": "node --experimental-specifier-resolution=node index.js --close",
    "balance": "node --experimental-specifier-resolution=node -e \"import('./wallet-utils.js').then(m=>m.getWalletBalances().then(b=>{console.log('Wallet:',b.wallet?.slice(0,10)+'...');console.log('SOL:',b.sol?.toFixed(4));b.tokens?.forEach(t=>console.log(t.symbol||t.mint?.slice(0,6),':',t.balance?.toFixed(4)))}))\""
  },
  "dependencies": {
    "@meteora-ag/dlmm": "^1.0.0",
    "@solana/web3.js": "^1.90.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^16.4.5"
  }
}
