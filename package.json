{
  "name": "simple-lp",
  "version": "2.0.0",
  "type": "module",
  "description": "Meteora DLMM pool screening & deploy bot — guided conversational CLI",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "screen": "node src/index.js screen",
    "positions": "node src/index.js positions",
    "close": "node src/index.js close",
    "balance": "node src/index.js balance",
    "menu": "node src/index.js menu",
    "dry": "DRY_RUN=true node src/index.js screen",

    "wallet:generate": "node src/wallet-generator.js generate",
    "wallet:import": "node src/wallet-generator.js import",
    "monitor": "node src/monitor.js",
    "monitor:once": "node src/monitor.js --once"
  },
  "dependencies": {
    "@meteora-ag/dlmm": "^1.0.0",
    "@solana/web3.js": "^1.90.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^16.4.5"
  }
}
